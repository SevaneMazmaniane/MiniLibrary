@page
@model MiniLibrary.Areas.Identity.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Register";
}

<section class="auth-card">
    <h1>Register</h1>
    <p>Create an account to borrow books, get AI insights, and track your loans.</p>

    <form method="post">
        <input type="hidden" asp-for="ReturnUrl" />
        <div asp-validation-summary="ModelOnly" class="alert error"></div>

        <label asp-for="Input.DisplayName">Display Name</label>
        <input asp-for="Input.DisplayName" autocomplete="name" />
        <span asp-validation-for="Input.DisplayName" class="text-error"></span>

        <label asp-for="Input.Email">Email</label>
        <input asp-for="Input.Email" type="email" autocomplete="email" />
        <span asp-validation-for="Input.Email" class="text-error"></span>

        <label asp-for="Input.Password">Password</label>
        <input asp-for="Input.Password" type="password" autocomplete="new-password" />
        <span asp-validation-for="Input.Password" class="text-error"></span>

        <label asp-for="Input.ConfirmPassword">Confirm Password</label>
        <input asp-for="Input.ConfirmPassword" type="password" autocomplete="new-password" />
        <span asp-validation-for="Input.ConfirmPassword" class="text-error"></span>

        <button type="submit">Create Account</button>
    </form>

    <p>
        Already have an account? <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl">Login</a>
    </p>
</section>
