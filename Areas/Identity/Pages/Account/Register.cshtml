@page
@model MiniLibrary.Areas.Identity.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Register";
}

<section class="auth-card">
    <h1>Create your account</h1>
    <p class="auth-subtitle">Join MiniLibrary to track and organize your collection.</p>

    <form method="post" class="auth-form">
        <div asp-validation-summary="ModelOnly" class="alert error"></div>

        <label asp-for="Input.DisplayName"></label>
        <input asp-for="Input.DisplayName" autocomplete="name" />
        <span asp-validation-for="Input.DisplayName" class="field-error"></span>

        <label asp-for="Input.Email"></label>
        <input asp-for="Input.Email" autocomplete="username" />
        <span asp-validation-for="Input.Email" class="field-error"></span>

        <label asp-for="Input.Password"></label>
        <input asp-for="Input.Password" autocomplete="new-password" />
        <span asp-validation-for="Input.Password" class="field-error"></span>

        <label asp-for="Input.ConfirmPassword"></label>
        <input asp-for="Input.ConfirmPassword" autocomplete="new-password" />
        <span asp-validation-for="Input.ConfirmPassword" class="field-error"></span>

        <button type="submit">Create account</button>
    </form>

    <p class="auth-footnote">
        Already have an account?
        <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl">Login</a>
    </p>
</section>
