@page
@model MiniLibrary.Areas.Identity.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Register";
}

<section class="auth-card card shadow-sm border-0">
    <div class="card-body p-4">
        <h1 class="h3 mb-2">Create your account</h1>
        <p class="auth-subtitle mb-4">Join MiniLibrary to track and organize your collection.</p>

        <form method="post" class="auth-form">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>

            <div class="mb-3">
                <label asp-for="Input.DisplayName" class="form-label"></label>
                <input asp-for="Input.DisplayName" autocomplete="name" class="form-control" />
                <span asp-validation-for="Input.DisplayName" class="field-error"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.Email" class="form-label"></label>
                <input asp-for="Input.Email" autocomplete="username" class="form-control" />
                <span asp-validation-for="Input.Email" class="field-error"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.Password" class="form-label"></label>
                <input asp-for="Input.Password" autocomplete="new-password" class="form-control" />
                <span asp-validation-for="Input.Password" class="field-error"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.ConfirmPassword" class="form-label"></label>
                <input asp-for="Input.ConfirmPassword" autocomplete="new-password" class="form-control" />
                <span asp-validation-for="Input.ConfirmPassword" class="field-error"></span>
            </div>

            <button type="submit" class="btn btn-ink w-100 auth-submit">Create account</button>
        </form>

        <p class="auth-footnote mt-3 mb-0 text-center">
            Already have an account?
            <a class="auth-link" asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl">Login</a>
        </p>
    </div>
</section>
