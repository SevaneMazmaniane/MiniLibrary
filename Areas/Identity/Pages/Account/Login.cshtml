@page
@model MiniLibrary.Areas.Identity.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Login";
}

<section class="auth-card">
    <h1>Login</h1>
    <p>Access your library account to borrow books and manage your profile.</p>

    <form method="post">
        <input type="hidden" asp-for="ReturnUrl" />
        <div asp-validation-summary="ModelOnly" class="alert error"></div>

        <label asp-for="Input.Email">Email</label>
        <input asp-for="Input.Email" type="email" autocomplete="email" />
        <span asp-validation-for="Input.Email" class="text-error"></span>

        <label asp-for="Input.Password">Password</label>
        <input asp-for="Input.Password" type="password" autocomplete="current-password" />
        <span asp-validation-for="Input.Password" class="text-error"></span>

        <label class="checkbox-label">
            <input asp-for="Input.RememberMe" /> @Html.DisplayNameFor(m => m.Input.RememberMe)
        </label>

        <button type="submit">Login</button>
    </form>

    @if (Model.ShowGoogleLogin)
    {
        <hr />
        <form asp-page="./ExternalLogin" asp-route-provider="Google" asp-route-returnUrl="@Model.ReturnUrl" method="post">
            <button type="submit">Continue with Google</button>
        </form>
    }

    <p>
        No account? <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Create one here</a>
    </p>
</section>
