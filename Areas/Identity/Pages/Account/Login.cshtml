@page
@model MiniLibrary.Areas.Identity.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Login";
}

<h1>Login</h1>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert error">@Model.ErrorMessage</div>
}

<form method="post">
    <label>Email <input asp-for="Input.Email" /></label>
    <span asp-validation-for="Input.Email"></span>

    <label>Password <input asp-for="Input.Password" type="password" /></label>
    <span asp-validation-for="Input.Password"></span>

    <label>
        <input asp-for="Input.RememberMe" /> Remember me
    </label>

    <button type="submit">Login</button>
</form>

@if (Model.ShowGoogleLogin)
{
    <hr />
    <form asp-page="./ExternalLogin" asp-route-provider="Google" asp-route-returnUrl="@Model.ReturnUrl" method="post">
        <button type="submit">Login with Google</button>
    </form>
}

<p>
    No account? <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Register here</a>
</p>

