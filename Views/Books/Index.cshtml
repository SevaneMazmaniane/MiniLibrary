@model BookListViewModel
@{
    var genres = ViewBag.Genres as List<string> ?? new List<string>();
    var aiTitle = TempData["AiSuggestTitle"] as string;
    var aiAuthor = TempData["AiSuggestAuthor"] as string;
    var aiGenre = TempData["AiSuggestGenre"] as string;
    var aiIsbn = TempData["AiSuggestIsbn"] as string;
    var showSuggestion = !string.IsNullOrWhiteSpace(aiTitle) && !string.IsNullOrWhiteSpace(aiAuthor);
}

<div class="hero-panel mb-4">
    <p class="ancient-subtitle mb-2">The Stoic Stacks</p>
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
        <div>
            <h1 class="h2 mb-2">Books & Borrowing Ledger</h1>
            <p class="mb-0 text-light-emphasis">A calm monochrome catalog for timeless reading rituals.</p>
        </div>
        @if (User.IsInRole("Admin"))
        {
            <div class="d-flex gap-2">
                <button type="button" class="btn btn-stone" data-bs-toggle="collapse" data-bs-target="#aiAddPanel" aria-expanded="@(showSuggestion ? "true" : "false")" aria-controls="aiAddPanel">Add with AI</button>
                <a asp-action="Create" class="btn btn-ink">+ Add Book</a>
            </div>
        }
    </div>
</div>

@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger">@error</div>
}
@if (TempData["AiInsights"] is string ai)
{
    <div class="alert alert-secondary border-dark-subtle">
        <strong>Gemini insights for @TempData["AiInsightsBook"]</strong>
        <pre class="mb-0 mt-2">@ai</pre>
    </div>
}
@if (TempData["AiRaw"] is string aiRaw)
{
    <div class="alert alert-light border border-dark-subtle">
        <strong>Raw AI response</strong>
        <pre class="mb-0 mt-2">@aiRaw</pre>
    </div>
}

@if (User.IsInRole("Admin"))
{
    <div class="collapse @(showSuggestion ? "show" : string.Empty) mb-4" id="aiAddPanel">
        <div class="pillar-card p-4">
            <h2 class="h5 mb-3">AI Book Draft</h2>
            <form asp-action="AiSuggestBook" method="post" class="row g-2 align-items-end">
                <div class="col-md-5">
                    <label for="aiTitle" class="form-label">Book name</label>
                    <input id="aiTitle" name="title" class="form-control" required />
                </div>
                <div class="col-md-5">
                    <label for="aiAuthor" class="form-label">Author name (optional)</label>
                    <input id="aiAuthor" name="author" class="form-control" />
                </div>
                <div class="col-md-2 d-grid">
                    <button type="submit" class="btn btn-ink">Submit</button>
                </div>
            </form>

            @if (showSuggestion)
            {
                <hr />
                <h3 class="h6">AI suggestion (confirm to add)</h3>
                <ul class="mb-3">
                    <li><strong>Title:</strong> @aiTitle</li>
                    <li><strong>Author:</strong> @aiAuthor</li>
                    <li><strong>Genre:</strong> @(string.IsNullOrWhiteSpace(aiGenre) ? "Unknown" : aiGenre)</li>
                    <li><strong>ISBN:</strong> @(string.IsNullOrWhiteSpace(aiIsbn) ? "Unknown" : aiIsbn)</li>
                </ul>

                <form asp-action="AddAiBook" method="post" class="d-inline">
                    <input type="hidden" name="title" value="@aiTitle" />
                    <input type="hidden" name="author" value="@aiAuthor" />
                    <input type="hidden" name="genre" value="@aiGenre" />
                    <input type="hidden" name="isbn" value="@aiIsbn" />
                    <button type="submit" class="btn btn-stone">Confirm & Add</button>
                </form>
            }
        </div>
    </div>
}

<form method="get" class="filter-panel mb-4">
    <div class="row g-2 align-items-end">
        <div class="col-md-6">
            <label class="form-label">Search scrolls</label>
            <input type="text" name="search" value="@Model.Search" placeholder="Search by title, author, ISBN" class="form-control" />
        </div>
        <div class="col-md-3">
            <label class="form-label">Genre</label>
            <select name="genre" class="form-select">
                <option value="">All genres</option>
                @foreach (var genre in genres)
                {
                    <option value="@genre" selected="@(genre == Model.Genre)">@genre</option>
                }
            </select>
        </div>
        <div class="col-md-3 d-flex gap-2">
            <button type="submit" class="btn btn-ink flex-fill">Search</button>
            <a asp-action="Index" class="btn btn-outline-ink">Reset</a>
        </div>
    </div>
</form>

<div class="table-scroll">
    <table class="table table-modern align-middle">
        <thead>
            <tr>
                <th>Title</th>
                <th>Author</th>
                <th>Genre</th>
                <th>ISBN</th>
                <th>Copies</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var b in Model.Books)
        {
            <tr>
                <td class="fw-semibold">@b.Title</td>
                <td>@b.Author</td>
                <td>@b.Genre</td>
                <td>@b.Isbn</td>
                <td><span class="badge mono-badge">@b.AvailableCopies/@b.TotalCopies</span></td>
                <td>
                    <div class="d-flex flex-wrap gap-2">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <form asp-action="Checkout" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@b.Id" />
                                <button type="submit" class="btn btn-sm btn-ink" @(b.AvailableCopies < 1 ? "disabled" : "")>Borrow</button>
                            </form>
                            <form asp-action="Checkin" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@b.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-ink">Return</button>
                            </form>
                            <form asp-action="AiInsights" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@b.Id" />
                                <button type="submit" class="btn btn-sm btn-stone">AI Insights</button>
                            </form>
                        }

                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-action="Edit" asp-route-id="@b.Id" class="btn btn-sm btn-stone">Edit</a>
                            <form asp-action="Delete" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@b.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                            </form>
                        }
                    </div>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
