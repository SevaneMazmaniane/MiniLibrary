@model BookListViewModel
@{
    var genres = ViewBag.Genres as List<string> ?? new List<string>();
    var showAiPanel = Model.AiCandidate is not null || !string.IsNullOrWhiteSpace(Model.AiInput.Title) || !string.IsNullOrWhiteSpace(Model.AiInput.Author);
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Mini Library Management</h1>
    @if (User.IsInRole("Admin"))
    {
        <div class="d-flex gap-2">
            <button class="btn btn-outline-primary" type="button" data-bs-toggle="collapse" data-bs-target="#addWithAiPanel" aria-expanded="false" aria-controls="addWithAiPanel">
                Add with AI
            </button>
            <a asp-action="Create" class="btn btn-success">+ Add Book</a>
        </div>
    }
</div>

@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger">@error</div>
}
@if (TempData["AiInsights"] is string ai)
{
    <div class="alert alert-info">
        <strong>Gemini insights for @TempData["AiInsightsBook"]</strong>
        <pre class="mb-0">@ai</pre>
    </div>
}

@if (User.IsInRole("Admin"))
{
    <div class="collapse mb-3 @(showAiPanel ? "show" : string.Empty)" id="addWithAiPanel">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <h2 class="h5">Add with AI</h2>
                <p class="text-muted mb-3">Enter a book title and optional author. AI will suggest details that you can confirm before saving.</p>
                <form asp-action="AddWithAi" method="post" class="row g-2">
                    <div class="col-md-5">
                        <label asp-for="AiInput.Title" class="form-label">Book name</label>
                        <input asp-for="AiInput.Title" class="form-control" required />
                    </div>
                    <div class="col-md-5">
                        <label asp-for="AiInput.Author" class="form-label">Author name (optional)</label>
                        <input asp-for="AiInput.Author" class="form-control" />
                    </div>
                    <div class="col-md-2 d-grid align-items-end">
                        <button type="submit" class="btn btn-primary mt-md-4">Submit</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    @if (Model.AiCandidate is not null)
    {
        <div class="card border-primary mb-3">
            <div class="card-header bg-primary text-white">AI Suggestion</div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <strong>Title:</strong> @Model.AiCandidate.Title
                    </div>
                    <div class="col-md-6">
                        <strong>Author:</strong> @Model.AiCandidate.Author
                    </div>
                    <div class="col-md-6">
                        <strong>Genre:</strong> @(Model.AiCandidate.Genre ?? "-")
                    </div>
                    <div class="col-md-6">
                        <strong>ISBN:</strong> @(Model.AiCandidate.Isbn ?? "-")
                    </div>
                </div>

                <form asp-action="ConfirmAddWithAi" method="post" class="mt-3 d-flex gap-2">
                    <input type="hidden" name="Title" value="@Model.AiCandidate.Title" />
                    <input type="hidden" name="Author" value="@Model.AiCandidate.Author" />
                    <input type="hidden" name="Genre" value="@Model.AiCandidate.Genre" />
                    <input type="hidden" name="Isbn" value="@Model.AiCandidate.Isbn" />
                    <button type="submit" class="btn btn-success">Confirm & Add</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </form>
            </div>
        </div>
    }
}

<form method="get" class="row g-2 mb-3">
    <div class="col-md-6">
        <input type="text" name="search" value="@Model.Search" placeholder="Search by title, author, ISBN" class="form-control" />
    </div>
    <div class="col-md-3">
        <select name="genre" class="form-select">
            <option value="">All genres</option>
            @foreach (var genre in genres)
            {
                <option value="@genre" selected="@(genre == Model.Genre)">@genre</option>
            }
        </select>
    </div>
    <div class="col-md-3 d-flex gap-2">
        <button type="submit" class="btn btn-primary">Search</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Reset</a>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Title</th>
                <th>Author</th>
                <th>Genre</th>
                <th>ISBN</th>
                <th>Copies</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var b in Model.Books)
        {
            <tr>
                <td>@b.Title</td>
                <td>@b.Author</td>
                <td>@b.Genre</td>
                <td>@b.Isbn</td>
                <td><span class="badge text-bg-secondary">@b.AvailableCopies/@b.TotalCopies</span></td>
                <td>
                    <div class="d-flex flex-wrap gap-2">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <form asp-action="Checkout" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@b.Id" />
                                <button type="submit" class="btn btn-sm btn-primary" @(b.AvailableCopies < 1 ? "disabled" : "")>Borrow</button>
                            </form>
                            <form asp-action="Checkin" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@b.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-primary">Return</button>
                            </form>
                            <form asp-action="AiInsights" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@b.Id" />
                                <button type="submit" class="btn btn-sm btn-info text-white">AI Insights</button>
                            </form>
                        }

                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-action="Edit" asp-route-id="@b.Id" class="btn btn-sm btn-warning">Edit</a>
                            <form asp-action="Delete" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@b.Id" />
                                <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                            </form>
                        }
                    </div>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
