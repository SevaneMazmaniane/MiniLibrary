@model Book

<form method="post" class="card shadow-sm">
    <div class="card-body">
        <input asp-for="Id" type="hidden" />

        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="Title" class="form-label"></label>
                <input asp-for="Title" class="form-control" />
            </div>
            <div class="col-md-6">
                <label asp-for="Author" class="form-label"></label>
                <input asp-for="Author" class="form-control" />
            </div>
            <div class="col-md-6">
                <label asp-for="Genre" class="form-label"></label>
                <input asp-for="Genre" class="form-control" />
            </div>
            <div class="col-md-6">
                <label asp-for="Isbn" class="form-label"></label>
                <input asp-for="Isbn" class="form-control" />
            </div>
            <div class="col-md-6">
                <label asp-for="Year" class="form-label"></label>
                <input asp-for="Year" type="number" class="form-control" />
            </div>
            <div class="col-md-6">
                <label asp-for="TotalCopies" class="form-label"></label>
                <input asp-for="TotalCopies" type="number" min="1" class="form-control" />
            </div>
            <div class="col-12">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="4"></textarea>
            </div>
        </div>
    </div>

    <div class="card-footer d-flex gap-2">
        <button type="submit" class="btn btn-ink">Save</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>
