@model MiniLibrary.Models.EventSearchViewModel
@{
    ViewData["Title"] = "Book & Art Events";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Book & Art Events</h1>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <a class="btn btn-primary" asp-action="Create">Create Event</a>
    }
</div>

<form method="get" class="card card-body mb-4">
    <div class="row g-3">
        <div class="col-md-3">
            <input asp-for="SearchTerm" class="form-control" placeholder="Title or description" />
        </div>
        <div class="col-md-2">
            <input asp-for="Location" class="form-control" placeholder="Location" />
        </div>
        <div class="col-md-2">
            <input asp-for="StartDate" class="form-control" type="date" />
        </div>
        <div class="col-md-2">
            <input asp-for="EndDate" class="form-control" type="date" />
        </div>
        <div class="col-md-2">
            <select asp-for="Category" asp-items="Html.GetEnumSelectList<MiniLibrary.Models.EventCategory>()" class="form-select">
                <option value="">All categories</option>
            </select>
        </div>
        <div class="col-md-1 d-grid">
            <button class="btn btn-outline-primary" type="submit">Find</button>
        </div>
    </div>
</form>

<div class="row g-3">
@foreach (var item in Model.Events)
{
    <div class="col-md-6 col-lg-4">
        <div class="card h-100 shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <h5 class="card-title">@item.Title</h5>
                    <span class="badge text-bg-secondary">@item.Category</span>
                </div>
                <p class="small text-muted mb-2">@item.StartAtUtc.ToLocalTime().ToString("f")</p>
                <p class="small text-muted mb-2">@item.Location</p>
                <p class="card-text">@((item.Description ?? "No description").Length > 140 ? (item.Description ?? "")[..140] + "..." : item.Description)</p>
            </div>
            <div class="card-footer bg-white border-0 pt-0 pb-3 px-3">
                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Details</a>
            </div>
        </div>
    </div>
}
</div>

@if (!Model.Events.Any())
{
    <div class="alert alert-info mt-3">No events matched your criteria.</div>
}
